# Database Connection (Supabase PostgreSQL — Transaction mode / Pooler)
# Host: aws-0-[region].pooler.supabase.com:6543
# User: postgres.[project-ref]
# Password: percent-encode special chars (? -> %3F, @ -> %40, * -> %2A)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase Project Credentials
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_[YOUR-KEY]
SUPABASE_SECRET_KEY=sb_secret_[YOUR-KEY]
SUPABASE_JWKS_URL=https://[PROJECT-REF].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=[YOUR-SUPABASE-JWT-SECRET]

# GPU Computation (Vast.ai)
VAST_API_KEY=[YOUR-VAST-AI-API-KEY]

# GPU Callbacks Configuration
# BACKEND_URL: public URL of this backend (GPU calls back to it)
# GPU_API_KEY: shared secret for GPU->backend callbacks (generate a UUID)
BACKEND_URL=http://localhost:8000
GPU_API_KEY=[GENERATE-WITH: python -c "import uuid; print(uuid.uuid4())"]
